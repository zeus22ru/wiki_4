# ============================================
# Конфигурация Wiki QA System
# ============================================
# Скопируйте этот файл в .env и измените значения по необходимости

# ============================================
# Сервер LLM (Ollama или LM Studio)
# ============================================
# Один переключатель задаёт пресет HTTP API:
#   ollama   → /api/embed, /api/generate, проверка /api/tags
#   lmstudio → /v1/embeddings, /v1/chat/completions, проверка /v1/models
#
#INFERENCE_BACKEND=ollama
#INFERENCE_BACKEND=lmstudio
#
# Базовый URL (Ollama по умолчанию :11434, LM Studio локальный сервер — часто :1234)
OLLAMA_URL=http://localhost:11434

# Идентификаторы моделей на сервере (у LM Studio — как в GET /v1/models, поле id)
OLLAMA_EMBEDDING_MODEL=bge-m3
OLLAMA_CHAT_MODEL=qwen2.5:7b

# Ручной override режима API (необязательно; перекрывает пресет INFERENCE_BACKEND):
#EMBEDDING_API_MODE=ollama
#EMBEDDING_API_MODE=openai
#CHAT_API_MODE=ollama
#CHAT_API_MODE=openai
#OPENAI_API_KEY=
#
# Максимум токенов в ответе чата (LM Studio max_tokens, Ollama num_predict). Было 500 — длинные ответы обрезались (finish_reason: length).
#CHAT_MAX_TOKENS=2048

# ============================================
# ChromaDB настройки
# ============================================
# Директория для хранения векторной базы данных
CHROMA_PERSIST_DIR=./chroma_db

# Имя коллекции в ChromaDB
CHROMA_COLLECTION_NAME=wiki_knowledge

# ============================================
# Data настройки
# ============================================
# Директория с исходными данными
DATA_DIR=./data

# Директория для загруженных файлов
UPLOAD_DIR=./data/uploads

# Размер чанка в символах для разбиения текста
CHUNK_SIZE=500

# Перекрытие чанков в символах
CHUNK_OVERLAP=50

# Размер пакета для пакетной обработки эмбеддингов
BATCH_SIZE=10

# ============================================
# API настройки
# ============================================
# Хост для запуска API сервера
API_HOST=0.0.0.0

# Порт для запуска API сервера
API_PORT=5000

# Режим отладки Flask (в продакшене: false)
#FLASK_DEBUG=false
#DEBUG=false

# CORS: "*" — любые origin; иначе список через запятую, например: http://localhost:5173,https://example.com
#CORS_ORIGINS=*

# Лимит чанков для вспомогательного поиска (не RAG pipeline)
TOP_K_RESULTS=3

# RAG: сколько чанков запрашивать в Chroma; порог релевантности (1 - distance)
#RAG_TOP_K=5
#RAG_MIN_SCORE=0.0
#RAG_MAX_CITATIONS=5

# ============================================
# Logging настройки
# ============================================
# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Директория для хранения логов
LOG_DIR=./logs

# ============================================
# Security настройки
# ============================================
# Секретный ключ для приложения (ОБЯЗАТЕЛЬНО ИЗМЕНИТЬ В ПРОДАКШЕНЕ!)
# Сгенерируйте случайный ключ: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# Секретный ключ для JWT токенов (ОБЯЗАТЕЛЬНО ИЗМЕНИТЬ В ПРОДАКШЕНЕ!)
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Время жизни JWT токена в часах
JWT_EXPIRATION_HOURS=24

# ============================================
# Database настройки
# ============================================
# Путь к файлу базы данных SQLite
DATABASE_PATH=./data/wiki_qa.db

# ============================================
# Cache настройки
# ============================================
# Включить кэширование эмбеддингов (true/false)
CACHE_ENABLED=true

# Время жизни кэша в секундах (по умолчанию 1 час)
CACHE_TTL=3600

# Директория для хранения кэша
CACHE_DIR=./cache

# ============================================
# File upload настройки
# ============================================
# Максимальный размер загружаемого файла в байтах (по умолчанию 10MB)
MAX_FILE_SIZE=10485760

# Разрешённые расширения файлов (через запятую)
ALLOWED_EXTENSIONS=html,htm,txt,docx,doc,pdf,xlsx,xls,pptx
