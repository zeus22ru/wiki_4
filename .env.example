# ============================================
# Конфигурация Wiki QA System
# ============================================
# Скопируйте этот файл в .env и измените значения по необходимости

# ============================================
# Ollama настройки
# ============================================
# URL для подключения к Ollama API
OLLAMA_URL=http://localhost:11434

# Модель для генерации эмбеддингов (рекомендуется bge-m3 для многоязычной поддержки)
OLLAMA_EMBEDDING_MODEL=bge-m3

# Модель для генерации ответов (рекомендуется qwen2.5:7b)
OLLAMA_CHAT_MODEL=qwen2.5:7b
#OLLAMA_CHAT_MODEL=bge-m3

# ============================================
# ChromaDB настройки
# ============================================
# Директория для хранения векторной базы данных
CHROMA_PERSIST_DIR=./chroma_db

# Имя коллекции в ChromaDB
CHROMA_COLLECTION_NAME=wiki_knowledge

# ============================================
# Data настройки
# ============================================
# Директория с исходными данными
DATA_DIR=./data

# Директория для загруженных файлов
UPLOAD_DIR=./data/uploads

# Размер чанка в символах для разбиения текста
CHUNK_SIZE=500

# Перекрытие чанков в символах
CHUNK_OVERLAP=50

# Размер пакета для пакетной обработки эмбеддингов
BATCH_SIZE=10

# ============================================
# API настройки
# ============================================
# Хост для запуска API сервера
API_HOST=0.0.0.0

# Порт для запуска API сервера
API_PORT=5000

# Количество релевантных документов для поиска
TOP_K_RESULTS=3

# ============================================
# Logging настройки
# ============================================
# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Директория для хранения логов
LOG_DIR=./logs

# ============================================
# Security настройки
# ============================================
# Секретный ключ для приложения (ОБЯЗАТЕЛЬНО ИЗМЕНИТЬ В ПРОДАКШЕНЕ!)
# Сгенерируйте случайный ключ: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# Секретный ключ для JWT токенов (ОБЯЗАТЕЛЬНО ИЗМЕНИТЬ В ПРОДАКШЕНЕ!)
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Время жизни JWT токена в часах
JWT_EXPIRATION_HOURS=24

# ============================================
# Database настройки
# ============================================
# Путь к файлу базы данных SQLite
DATABASE_PATH=./data/wiki_qa.db

# ============================================
# Cache настройки
# ============================================
# Включить кэширование эмбеддингов (true/false)
CACHE_ENABLED=true

# Время жизни кэша в секундах (по умолчанию 1 час)
CACHE_TTL=3600

# Директория для хранения кэша
CACHE_DIR=./cache

# ============================================
# File upload настройки
# ============================================
# Максимальный размер загружаемого файла в байтах (по умолчанию 10MB)
MAX_FILE_SIZE=10485760

# Разрешённые расширения файлов (через запятую)
ALLOWED_EXTENSIONS=html,htm,txt,docx,doc,pdf,xlsx,xls,pptx
